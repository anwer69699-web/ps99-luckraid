    --                     AUTO TAP - POWERFUL
    -- ═══════════════════════════════════════════════════════════════
    
    RunService.Heartbeat:Connect(function()
        if not Settings.AutoTap then return end
        
        local target = GetBestTarget()
        if not target then return end
        
        local hitbox = target:FindFirstChild("Hitbox", true)
        if not hitbox then return end
        
        if Settings.TapTeleport then
            pcall(function()
                local root = GetRoot()
                local targetPos = hitbox.Position
                root.CFrame = CFrame.new(targetPos.X, targetPos.Y + Settings.TELEPORT_HEIGHT, targetPos.Z)
            end)
        end
        
        local hpObj = target:FindFirstChild("Health", true)
        local hp = hpObj and hpObj.Value or 999999
        
        local burst = Settings.BASE_BURST
        if hp < 3000 then
            burst = burst * 4
        elseif hp < 10000 then
            burst = burst * 2
        end
        
        for i = 1, burst do
            pcall(function()
                DamageRemote:FireServer(target.Name)
                Stats.Taps = Stats.Taps + 1
            end)
        end
    end)
    
