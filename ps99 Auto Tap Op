    CreateToggle(MainTab, "Anti AFK", "AntiAFK")
    CreateToggle(MainTab, "Priority Small", "PRIORITY_SMALL")
    
    -- Settings Tab
    CreateSlider(SettingsTab, "Push Speed", "VELOCITY_SPEED", 50, 500, 200)
    CreateSlider(SettingsTab, "Tap Power", "BASE_BURST", 10, 200, 50)
    CreateSlider(SettingsTab, "Range", "RANGE", 1000, 20000, 5000)
    CreateSlider(SettingsTab, "TP Height", "TELEPORT_HEIGHT", 2, 15, 4)
    
    -- Stats Tab
    local orbsStat = CreateStat(StatsTab, "Orbs Collected", Color3.fromRGB(0, 255, 120), 6)
    local lootStat = CreateStat(StatsTab, "Lootbags", Color3.fromRGB(255, 170, 0), 66)
    local tapsStat = CreateStat(StatsTab, "Total Taps", Color3.fromRGB(255, 70, 70), 126)
    local timeStat = CreateStat(StatsTab, "Session Time", Color3.fromRGB(170, 100, 255), 186)
    
    -- Update Stats
    task.spawn(function()
        while true do
            orbsStat.Text = tostring(Stats.Orbs)
            lootStat.Text = tostring(Stats.Lootbags)
            tapsStat.Text = tostring(Stats.Taps)
            
            local elapsed = tick() - Stats.Start
            timeStat.Text = string.format("%02d:%02d", math.floor(elapsed / 60), math.floor(elapsed % 60))
            
            wait(0.2)
        end
    end)
    
    -- Controls
    closeBtn.MouseButton1Click:Connect(function() gui:Destroy() end)
    
    local minimized = false
    minBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        TweenService:Create(main, TweenInfo.new(0.25), {
            Size = minimized and UDim2.new(0, 400, 0, 45) or UDim2.new(0, 400, 0, 300)
        }):Play()
        content.Visible = not minimized
        sidebar.Visible = not minimized
        minBtn.Text = minimized and "+" or "−"
    end)
    
    -- Drag
    local dragging, dragStart, startPos = false, nil, nil
    header.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging, dragStart, startPos = true, input.Position, main.Position
        end
    end)
    header.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    
    -- Toggle Key
    UserInputService.InputBegan:Connect(function(input, gp)
        if not gp and input.KeyCode == Enum.KeyCode.RightShift then
            main.Visible = not main.Visible
        end
    end)
    
    print("✅ AirFlow Natural Loaded!")
    print("🚀 Push System: Velocity toward player")
    print("🛑 Stop at 2 studs - Let server collect naturally")
    print("🔧 Press RightShift to toggle GUI")
end)
