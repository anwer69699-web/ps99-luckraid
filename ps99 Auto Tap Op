    -- نظام جمع الدفعات للأشياء القريبة (يحسبهم بس، ما يدمرهم)
    task.spawn(function()
        while true do
            if Settings.AutoCollect then
                local root = GetRoot()
                local nearbyOrbs = 0
                local nearbyBags = 0
                
                -- عد الأوربس القريبة (2 ستود أو أقل)
                for _, orb in ipairs(Orbs:GetChildren()) do
                    local dist = (orb.Position - root.Position).Magnitude
                    if dist <= Settings.STOP_DISTANCE + 1 then
                        nearbyOrbs = nearbyOrbs + 1
                        -- وقف التحريك
                        pcall(function()
                            orb.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                        end)
                    else
                        PushOrbToPlayer(orb)
                    end
                end
                
                -- عد اللوتباجز القريبة
                for _, bag in ipairs(Lootbags:GetChildren()) do
                    local dist = (bag.Position - root.Position).Magnitude
                    if dist <= Settings.STOP_DISTANCE + 1 then
                        nearbyBags = nearbyBags + 1
                        pcall(function()
                            bag.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                        end)
                    else
                        PushLootbagToPlayer(bag)
                    end
                end
                
                -- تحديث الإحصائيات (تقديرية)
