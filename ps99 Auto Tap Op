        sliderBg.BackgroundColor3 = Color3.fromRGB(30, 30, 50)
        Instance.new("UICorner", sliderBg).CornerRadius = UDim.new(0, 3)
        
        local fill = Instance.new("Frame", sliderBg)
        fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
        fill.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
        Instance.new("UICorner", fill).CornerRadius = UDim.new(0, 3)
        
        local handle = Instance.new("Frame", sliderBg)
        handle.Size = UDim2.new(0, 14, 0, 14)
        handle.Position = UDim2.new((default - min) / (max - min), -7, 0.5, -7)
        handle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        Instance.new("UICorner", handle).CornerRadius = UDim.new(1, 0)
        
        local dragging = false
        local dragArea = Instance.new("TextButton", frame)
        dragArea.Size = UDim2.new(1, -20, 0, 28)
        dragArea.Position = UDim2.new(0, 10, 0, 22)
        dragArea.BackgroundTransparency = 1
        dragArea.Text = ""
        
        local function Update(val)
            val = math.clamp(val, min, max)
            local pct = (val - min) / (max - min)
            fill.Size = UDim2.new(pct, 0, 1, 0)
            handle.Position = UDim2.new(pct, -7, 0.5, -7)
            valueBox.Text = string.format("%.0f", val)
            Settings[key] = val
        end
        
        dragArea.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                local pos = input.Position.X
                local sp = sliderBg.AbsolutePosition.X
                local sw = sliderBg.AbsoluteSize.X
                Update(min + (max - min) * math.clamp((pos - sp) / sw, 0, 1))
            end
        end)
        
        UserInputService.InputChanged:Connect(function(input)
            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                local pos = input.Position.X
                local sp = sliderBg.AbsolutePosition.X
                local sw = sliderBg.AbsoluteSize.X
                Update(min + (max - min) * math.clamp((pos - sp) / sw, 0, 1))
            end
        end)
        
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
        end)
        return frame
    end
    
