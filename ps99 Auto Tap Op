pcall(function()

-- SERVICES
local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")
local WS = game:GetService("Workspace")
local RunService = game:GetService("RunService")

local Player = Players.LocalPlayer

-- REMOTES
local Net = RS:WaitForChild("Network")
local DamageRemote = Net:WaitForChild("Breakables_PlayerDealDamage")
local CollectRemote = Net:WaitForChild("Orbs: Collect")

-- WORLD
local Breakables = WS:WaitForChild("__THINGS"):WaitForChild("Breakables")
local Orbs = WS:WaitForChild("__THINGS"):WaitForChild("Orbs")
local Lootbags = WS:WaitForChild("__THINGS"):WaitForChild("Lootbags")

-- STATE
local AutoTap = false
local TapTeleport = false
local AutoCollect = false

-- SETTINGS
local RANGE = 5000
local BASE_BURST = 25

-- CHARACTER
local function GetRoot()
    local char = Player.Character or Player.CharacterAdded:Wait()
    return char:WaitForChild("HumanoidRootPart")
end

-- 🧠 SMART TARGET
local function GetTarget()
    local best, bestScore = nil, math.huge
    local root = GetRoot()

    for _, v in ipairs(Breakables:GetChildren()) do
        local hitbox = v:FindFirstChild("Hitbox", true)
        if hitbox then
            local dist = (root.Position - hitbox.Position).Magnitude
            if dist <= RANGE then
                local hpObj = v:FindFirstChild("Health", true)
                local hp = hpObj and hpObj.Value or 999999

                local score = hp + (dist * 2)

                if score < bestScore then
                    bestScore = score
                    best = v
                end
            end
        end
    end

    return best
end

-- 💀 AUTO TAP
RunService.Heartbeat:Connect(function()
    if not AutoTap then return end

    local target = GetTarget()
    if not target then return end

    local hitbox = target:FindFirstChild("Hitbox", true)
    if not hitbox then return end

    if TapTeleport then
        pcall(function()
            GetRoot().CFrame = hitbox.CFrame + Vector3.new(0,3,0)
        end)
    end

    local hpObj = target:FindFirstChild("Health", true)
    local hp = hpObj and hpObj.Value or 999999

    local burst = BASE_BURST
    if hp < 5000 then
        burst = BASE_BURST * 2
    elseif hp < 20000 then
        burst = BASE_BURST * 1.5
    end

    for i = 1, burst do
        pcall(function()
            DamageRemote:FireServer(target.Name)
        end)
    end
end)

-- 💰 AUTO COLLECT
task.spawn(function()
    while true do
        if AutoCollect then
            local ids = {}

            for _, orb in ipairs(Orbs:GetChildren()) do
                local id = tonumber(orb.Name)
                if id then
                    table.insert(ids, id)
                    orb:Destroy()
                end
            end

            if #ids > 0 then
                pcall(function()
                    CollectRemote:FireServer(ids)
                end)
            end

            for _, bag in ipairs(Lootbags:GetChildren()) do
                bag:Destroy()
            end
        end

        task.wait(0.1)
    end
end)

-- ⚡ Collect عند السبون
Orbs.ChildAdded:Connect(function(orb)
    if AutoCollect then
        task.wait()
        local id = tonumber(orb.Name)
        if id then
            pcall(function()
                CollectRemote:FireServer({id})
            end)
            orb:Destroy()
        end
    end
end)

-- 🖥️ GUI بسيط
local gui = Instance.new("ScreenGui", game.CoreGui)
gui.Name = "ARBIX_SIMPLE"

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0, 260, 0, 170)
frame.Position = UDim2.new(0.5,-130,0.5,-85)
frame.BackgroundColor3 = Color3.fromRGB(25,25,35)
frame.Active = true
frame.Draggable = true
Instance.new("UICorner", frame)

local title = Instance.new("TextLabel", frame)
title.Size = UDim2.new(1,0,0,30)
title.BackgroundTransparency = 1
title.Text = "ARBIX SIMPLE"
title.TextColor3 = Color3.new(1,1,1)
title.TextScaled = true

local function Button(name, y, callback)
    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(1,-20,0,35)
    btn.Position = UDim2.new(0,10,0,y)
    btn.BackgroundColor3 = Color3.fromRGB(40,40,60)
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Text = name..": OFF"
    Instance.new("UICorner", btn)

    local state = false
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.Text = name..": "..(state and "ON" or "OFF")
        callback(state)
    end)
end

Button("Auto Tap", 45, function(v) AutoTap = v end)
Button("Teleport", 85, function(v) TapTeleport = v end)
Button("Auto Collect", 125, function(v) AutoCollect = v end)

end)
