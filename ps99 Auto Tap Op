    -- ═══════════════════════════════════════════════════════════════
    --                     TARGET SYSTEM - FOCUS ONE
    -- ═══════════════════════════════════════════════════════════════
    
    local CurrentTarget = nil
    
    local function GetBestTarget()
        local root = GetRoot()
        local best, bestScore = nil, math.huge
        
        if CurrentTarget and CurrentTarget.Parent then
            local hpObj = CurrentTarget:FindFirstChild("Health", true)
            local hp = hpObj and hpObj.Value or 0
            if hp > 0 then
                local hitbox = CurrentTarget:FindFirstChild("Hitbox", true)
                if hitbox then
                    local dist = (root.Position - hitbox.Position).Magnitude
                    if dist <= Settings.RANGE then
                        return CurrentTarget
                    end
                end
            end
        end
        
        for _, v in ipairs(Breakables:GetChildren()) do
            local hitbox = v:FindFirstChild("Hitbox", true)
            if hitbox then
                local dist = (root.Position - hitbox.Position).Magnitude
                if dist <= Settings.RANGE then
                    local hpObj = v:FindFirstChild("Health", true)
                    local maxHpObj = v:FindFirstChild("MaxHealth", true)
                    local hp = hpObj and hpObj.Value or 999999
                    local maxHp = maxHpObj and maxHpObj.Value or hp
                    
                    if hp > 0 then
                        local score = dist
                        
                        if Settings.PRIORITY_SMALL then
                            if maxHp < 5000 then
                                score = score * 0.2
                            elseif maxHp < 20000 then
                                score = score * 0.5
                            end
                        end
                        
                        if score < bestScore then
                            bestScore = score
                            best = v
                        end
                    end
                end
            end
        end
        
        CurrentTarget = best
        return best
    end
    
