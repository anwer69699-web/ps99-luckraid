pcall(function()

--// SERVICES
local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")
local WS = game:GetService("Workspace")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

local Player = Players.LocalPlayer

--// REMOTES
local Net = RS:WaitForChild("Network")
local DamageRemote = Net:WaitForChild("Breakables_PlayerDealDamage")

--// WORLD
local Breakables = WS:WaitForChild("__THINGS"):WaitForChild("Breakables")

--// SETTINGS
local Settings = {
    Enabled = false,
    RiskMode = false,
    Range = 3500
}

local Cache = {}
local pointer = 1
local lastFire = 0

--// TARGET
local function UpdateTargets()
    table.clear(Cache)

    local char = Player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local pos = hrp.Position

    for _, v in ipairs(Breakables:GetChildren()) do
        local hit = v:FindFirstChild("Hitbox", true)
        if hit then
            local dist = (pos - hit.Position).Magnitude
            if dist < Settings.Range then
                table.insert(Cache, {obj=v, dist=dist})
            end
        end
    end

    table.sort(Cache, function(a,b)
        return a.dist < b.dist
    end)
end

--// 🔥 AIRFLOW CORE (UPGRADED)
local function Airflow()
    if not Settings.Enabled then return end

    local delay = Settings.RiskMode and 0.03 or 0.065
    if tick() - lastFire < delay then return end
    lastFire = tick()

    UpdateTargets()
    local count = #Cache
    if count == 0 then return end

    -- 🎯 إعدادات ذكية
    local burst = Settings.RiskMode and math.clamp(count * 1.5, 40, 90) or 25
    local flow = Settings.RiskMode and math.clamp(count * 3, 80, 160) or 45

    -- 🔥 Burst مركز
    local main = Cache[1]
    if main then
        for i = 1, burst do
            DamageRemote:FireServer(main.obj.Name)
        end
    end

    -- 🌊 Flow توزيع سريع
    for i = 1, flow do
        local t = Cache[pointer]

        if not t then
            pointer = 1
            t = Cache[pointer]
        end

        if t then
            DamageRemote:FireServer(t.obj.Name)
        end

        pointer += 1
        if pointer > count then pointer = 1 end
    end

    -- ⚡ Boost إضافي خفيف (Risk فقط)
    if Settings.RiskMode and count > 3 then
        for i = 1, 10 do
            local rand = Cache[math.random(1, math.min(count, 5))]
            if rand then
                DamageRemote:FireServer(rand.obj.Name)
            end
        end
    end
end

--// UI
local gui = Instance.new("ScreenGui", game.CoreGui)
gui.Name = "AirflowMini"

local main = Instance.new("Frame", gui)
main.Size = UDim2.new(0, 220, 0, 140)
main.Position = UDim2.new(0.5, -110, 0.5, -70)
main.BackgroundColor3 = Color3.fromRGB(18,18,26)
main.Active = true
main.Draggable = true

Instance.new("UICorner", main).CornerRadius = UDim.new(0,10)

local stroke = Instance.new("UIStroke", main)
stroke.Color = Color3.fromRGB(120,170,255)
stroke.Transparency = 0.5
stroke.Thickness = 1.2

--// 🌈 TITLE (ULTRA SMOOTH RAINBOW)

local title = Instance.new("TextLabel", main)
title.Size = UDim2.new(1,0,0,30)
title.BackgroundTransparency = 1
title.Text = "Auto Tap Hub"
title.TextScaled = true
title.Font = Enum.Font.GothamBold
title.TextColor3 = Color3.new(1,1,1)

local rainbow = Instance.new("UIGradient", title)
rainbow.Rotation = 45

local hue = 0

RunService.RenderStepped:Connect(function(dt)
    hue += dt * 0.15 -- أبطأ = أفخم

    if hue > 1 then hue -= 1 end

    rainbow.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromHSV(hue,1,1)),
        ColorSequenceKeypoint.new(0.5, Color3.fromHSV((hue+0.15)%1,1,1)),
        ColorSequenceKeypoint.new(1, Color3.fromHSV((hue+0.3)%1,1,1))
    }
end)

--// BUTTONS

local function createButton(text, y, callback)
    local btn = Instance.new("TextButton", main)
    btn.Size = UDim2.new(1,-20,0,40)
    btn.Position = UDim2.new(0,10,0,y)
    btn.Text = text.." : OFF"
    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.BackgroundColor3 = Color3.fromRGB(40,40,60)

    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,8)

    local state = false

    btn.MouseButton1Click:Connect(function()
        state = not state

        btn.Text = text.." : "..(state and "ON" or "OFF")

        TweenService:Create(btn, TweenInfo.new(0.2), {
            BackgroundColor3 = state and Color3.fromRGB(70,140,255) or Color3.fromRGB(40,40,60)
        }):Play()

        callback(state)
    end)
end

createButton("ENABLE", 35, function(v)
    Settings.Enabled = v
end)

createButton("OP MODE", 80, function(v)
    Settings.RiskMode = v
end)

--// LOOP
RunService.Heartbeat:Connect(Airflow)

end)
