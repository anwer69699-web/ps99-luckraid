    --                     NATURAL VELOCITY SYSTEM
    --              يدفع الأوربس واللوتباجز بسرعة عالية
    --         لما يوصلوا لـ 2 ستود، يوقف التحريك ويخلي اللعبة تجمعهم
    -- ═══════════════════════════════════════════════════════════════
    
    local TrackedItems = {}
    
    local function PushOrbToPlayer(orb)
        if not orb or not orb.Parent then return end
        if not Settings.AutoCollect then return end
        
        local root = GetRoot()
        local orbId = tonumber(orb.Name)
        if not orbId then return end
        
        -- لو قريب جداً (2 ستود أو أقل)، وقف التحريك وخلي اللعبة تجمعه
        local dist = (orb.Position - root.Position).Magnitude
        if dist <= Settings.STOP_DISTANCE then
            -- وقف التحريك وخلي اللعبة تتولى
            pcall(function()
                orb.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                -- لا تسوي destroy هنا، خل اللعبة تجمعه طبيعي
            end)
            return
        end
        
        -- لو بعيد، شغل Velocity
        if not TrackedItems[orb] then
            TrackedItems[orb] = true
            
            task.spawn(function()
                local reached = false
                
                while orb and orb.Parent and Settings.AutoCollect and not reached do
                    local playerPos = GetRoot().Position
                    local orbPos = orb.Position
                    local direction = (playerPos - orbPos).Unit
                    local currentDist = (playerPos - orbPos).Magnitude
                    
                    -- إذا وصل لـ 2 ستود، وقف التحريك
                    if currentDist <= Settings.STOP_DISTANCE then
                        pcall(function()
                            orb.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                        end)
                        reached = true
                        break
                    end
                    
                    -- سرعة عالية نحو اللاعب
                    local velocity = direction * Settings.VELOCITY_SPEED
                    
                    pcall(function()
                        orb.AssemblyLinearVelocity = velocity
                    end)
                    
                    RunService.Heartbeat:Wait()
                end
                
                TrackedItems[orb] = nil
            end)
        end
    end
    
    local function PushLootbagToPlayer(bag)
        if not bag or not bag.Parent then return end
        if not Settings.AutoCollect then return end
        
        local root = GetRoot()
        local dist = (bag.Position - root.Position).Magnitude
        
        if dist <= Settings.STOP_DISTANCE then
            pcall(function()
                bag.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            end)
            return
        end
        
        if not TrackedItems[bag] then
            TrackedItems[bag] = true
            
            task.spawn(function()
                local reached = false
                
                while bag and bag.Parent and Settings.AutoCollect and not reached do
                    local playerPos = GetRoot().Position
                    local bagPos = bag.Position
                    local direction = (playerPos - bagPos).Unit
                    local currentDist = (playerPos - bagPos).Magnitude
                    
                    if currentDist <= Settings.STOP_DISTANCE then
                        pcall(function()
                            bag.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                        end)
                        reached = true
                        break
                    end
                    
                    local velocity = direction * Settings.VELOCITY_SPEED
                    
                    pcall(function()
                        bag.AssemblyLinearVelocity = velocity
                    end)
                    
                    RunService.Heartbeat:Wait()
                end
                
                TrackedItems[bag] = nil
            end)
        end
    end
    
    -- مراقبة الأوربس الجديدة
